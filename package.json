{
    "name": "@leesorry/dyna-form",
    "version": "1.0.0",
    "description": "DynaForm - A Data-Driven Vue 2 Form Component Library",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/leepule/DynaForm.git"
    },
    "homepage": "https://leepule.github.io/DynaForm",
    "bugs": {
        "url": "https://github.com/leepule/DynaForm/issues"
    },
    "main": "dist/dyna-form.common.js",
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "package.json"
    ],
    "keywords": [
        "vue",
        "element-ui",
        "form",
        "dyna-form",
        "date-picker",
        "period-picker",
        "person-picker"
    ],
    "scripts": {
        "serve": "vue-cli-service serve demo/main.js",
        "build:lib": "vue-cli-service build --target lib --name dyna-form src/index.js",
        "test": "echo \"Error: no test specified\" && exit 1",
        "docs:install": "cd docs && npm install",
        "docs:dev": "cd docs && npm run dev",
        "docs:build": "cd docs && npm run build",
        "docs:deploy": "sh deploy.sh",
        "release": "sh release.sh"
    },
    "peerDependencies": {
        "vue": "2.7.16",
        "element-ui": "2.15.14"
    },
    "peerDependenciesMeta": {
        "element-ui": {
            "optional": true
        }
    },
    "author": "",
    "license": "Apache-2.0",
    "devDependencies": {
        "@vue/cli-plugin-babel": "^5.0.9",
        "@vue/cli-service": "^5.0.9",
        "element-ui": "^2.15.14",
        "sass": "^1.97.2",
        "sass-loader": "^16.0.6",
        "vue": "^2.7.16",
        "vue-template-compiler": "^2.7.16"
    }
}